# FlowTest Environment Variables Template
# Copy this file to .env.local for local development

# ----------------------------------------------------
# 1. Required for Live Browser Automation
# ----------------------------------------------------
# Get your API key from the Browserbase console: https://www.browserbase.com
BROWSERBASE_API_KEY=

# ----------------------------------------------------
# 2. Optional: For Testing / Mock Mode
# ----------------------------------------------------
# Set to "true" to run tests locally with a simulated browser environment.
# This does not require any API credentials or make network calls.
MOCK_BROWSER=false

# ----------------------------------------------------
# 3. Optional: Separate LLM API Key (If not using Model Gateway)
# ----------------------------------------------------
# Google Gemini API key used for advanced test planning.
# If omitted and Browserbase key is set, Stagehand will route LLM queries
# through the Browserbase Model Gateway automatically.
GEMINI_API_KEY=
